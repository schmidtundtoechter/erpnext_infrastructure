## Source setup
# This is the scenario component name which will be automatically filled. Default is ignored but must not be empty.
SCENARIO_SRC_COMPONENT="com/axllent/mailpit/1.x"
# This is the cache directory for downloaded files, like structr.zip or WODA-current.tar.gz
SCENARIO_SRC_CACHEDIR="~/.cache/MIMS-Scenarios"
# This is the directory storing secrets for docker containers
SCENARIO_SRC_SECRETSDIR="/var/dev/MIMS-Scenarios/_secrets"
## Server setup
# What is the server, the scenario will be deployed to?
SCENARIO_SERVER_NAME="test.schmidtundtoechter.com"
# What is the SSH config the server can be connected with?
SCENARIO_SERVER_SSHCONFIG="sut.netcup"
# What is the scenarios root directory on the server?
SCENARIO_SERVER_CONFIGSDIR="/var/dev/MIMS-Scenarios"
## Config data setup
# What is the path used to store the mailpit data (e.g. './mailpit-data' or 'mailpit-volume'; if it contains a '/', it is considered as a path, otherwise as a docker volume name)?
SCENARIO_DATA_VOLUME_1_PATH="mailpit-volume"
# Is the data volume external (true or false; if not external, it will be deleted on down)?
SCENARIO_DATA_VOLUME_1_EXTERNAL="true"
# What is the path used to store the volume backups
SCENARIO_DATA_BACKUPDIR="/var/dev/MIMS-Scenarios/_backups"
## Unique resources
# What is the web ui port of the docker container?
SCENARIO_RESOURCE_WEBUIPORT="8025"
# What is the smtp port of the docker container?
SCENARIO_RESOURCE_SMTPPORT="1025"
## Mailpit setup
# Max number of messages to keep in database
SCENARIO_MAILPIT_MAXMESSAGES="5000"
# Accept any SMTP auth credentials (1 means true, 0 means false)
SCENARIO_MAILPIT_SMTPAUTHACCEPTANY="1"
# Allow insecure SMTP auth without TLS (1 means true, 0 means false)
SCENARIO_MAILPIT_SMTPAUTHALLOWINSECURE="1"
## Traefik proxy setup
# Do you want to route this service via traefik?
SCENARIO_TRAEFIK_ENABLE="true"
# What is the url of the mailpit service?
SCENARIO_TRAEFIK_MAILPIT_URL="mailpit.test.schmidtundtoechter.com"
# Route to service (this service must support other routes than '/')
SCENARIO_TRAEFIK_MAILPIT_ROUTE="/"
# What is the traefik proxy network name?
SCENARIO_TRAEFIK_NETWORK_NAME="traefik"
