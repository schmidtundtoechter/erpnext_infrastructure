#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck source=../lib/common.sh
source "${ROOT_DIR}/lib/common.sh"
# shellcheck source=../lib/log.sh
source "${ROOT_DIR}/lib/log.sh"
# shellcheck source=../lib/config.sh
source "${ROOT_DIR}/lib/config.sh"
# shellcheck source=../lib/nodes.sh
source "${ROOT_DIR}/lib/nodes.sh"
# shellcheck source=../lib/backup-model.sh
source "${ROOT_DIR}/lib/backup-model.sh"
# shellcheck source=../lib/scan.sh
source "${ROOT_DIR}/lib/scan.sh"
# shellcheck source=../lib/backup.sh
source "${ROOT_DIR}/lib/backup.sh"
# shellcheck source=../lib/copy.sh
source "${ROOT_DIR}/lib/copy.sh"
# shellcheck source=../lib/restore.sh
source "${ROOT_DIR}/lib/restore.sh"
# shellcheck source=../lib/cache.sh
source "${ROOT_DIR}/lib/cache.sh"
# shellcheck source=../lib/list.sh
source "${ROOT_DIR}/lib/list.sh"

backupctl_usage() {
  cat <<'EOF'
Usage: backupctl [--config <path>] [--dry-run] <command> [options]

Commands:
  nodes list       List configured nodes
  scan             Discover backups on configured nodes
  list             List backups from cache (text/json, with filters)
  create           Create backup on frappe-backup-dir sources
  copy             Copy backup between nodes
  restore          Restore backup to target site
  cache rebuild    Rebuild cache from discovered backups
  cache clear      Clear local cache file
  help             Show this help or command help

Examples:
  backupctl help scan
  backupctl scan --help
  backupctl --dry-run copy --backup <id> --from <src> --to <dst>
EOF
}

nodes_usage() {
  cat <<'EOF'
Usage: backupctl nodes list

Subcommands:
  list             List configured nodes
EOF
}

cache_usage() {
  cat <<'EOF'
Usage: backupctl cache <subcommand>

Subcommands:
  rebuild          Rebuild cache from scan results
  clear            Clear local cache file
EOF
}

backupctl_command_help() {
  local topic="${1:-}"

  case "${topic}" in
    ""|main)
      backupctl_usage
      ;;
    nodes)
      nodes_usage
      ;;
    scan)
      scan_usage
      ;;
    list)
      list_usage
      ;;
    create)
      backup_create_usage
      ;;
    copy)
      backup_copy_usage
      ;;
    restore)
      backup_restore_usage
      ;;
    cache)
      cache_usage
      ;;
    *)
      bt_die "Unknown help topic: ${topic}"
      ;;
  esac
}

main() {
  local config_path=""
  local dry_run_global=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        [[ $# -ge 2 ]] || bt_die "--config requires a value"
        config_path="$2"
        shift 2
        ;;
      --dry-run)
        dry_run_global=1
        shift
        ;;
      -h|--help)
        backupctl_usage
        return
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    backupctl_usage
    exit 1
  fi

  if [[ -n "${config_path}" ]]; then
    bt_load_config "${config_path}"
  fi

  if [[ "${dry_run_global}" -eq 1 ]]; then
    BT_RUNNER_MODE="dry-run"
    export BT_RUNNER_MODE
  fi

  local command="$1"
  shift || true

  case "${command}" in
    help|-h|--help)
      backupctl_command_help "${1:-}"
      ;;
    nodes)
      if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
        nodes_usage
        return
      fi
      local subcommand="${1:-}"
      if [[ "${subcommand}" != "list" ]]; then
        bt_die "Unknown nodes subcommand: ${subcommand:-<empty>}"
      fi
      shift || true
      if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
        nodes_usage
        return
      fi
      nodes_list "$@"
      ;;
    scan)
      scan_main "$@"
      ;;
    list)
      list_main "$@"
      ;;
    create)
      backup_create_main "$@"
      ;;
    copy)
      backup_copy_main "$@"
      ;;
    restore)
      if [[ "${dry_run_global}" -eq 1 ]]; then
        backup_restore_main --dry-run "$@"
      else
      backup_restore_main "$@"
      fi
      ;;
    cache)
      if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
        cache_usage
        return
      fi
      local cache_subcommand="${1:-}"
      case "${cache_subcommand}" in
        rebuild)
          shift || true
          if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
            cache_usage
            return
          fi
          cache_rebuild_main "$@"
          ;;
        clear)
          shift || true
          if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
            cache_usage
            return
          fi
          cache_clear_main "$@"
          ;;
        *)
          bt_die "Unknown cache subcommand: ${cache_subcommand:-<empty>}"
          ;;
      esac
      ;;
    *)
      bt_die "Unknown command: ${command}"
      ;;
  esac
}

main "$@"