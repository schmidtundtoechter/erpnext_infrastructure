#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck source=../lib/common.sh
source "${ROOT_DIR}/lib/common.sh"
# shellcheck source=../lib/log.sh
source "${ROOT_DIR}/lib/log.sh"
# shellcheck source=../lib/config.sh
source "${ROOT_DIR}/lib/config.sh"
# shellcheck source=../lib/nodes.sh
source "${ROOT_DIR}/lib/nodes.sh"
# shellcheck source=../lib/backup-model.sh
source "${ROOT_DIR}/lib/backup-model.sh"
# shellcheck source=../lib/scan.sh
source "${ROOT_DIR}/lib/scan.sh"
# shellcheck source=../lib/backup.sh
source "${ROOT_DIR}/lib/backup.sh"
# shellcheck source=../lib/copy.sh
source "${ROOT_DIR}/lib/copy.sh"
# shellcheck source=../lib/restore.sh
source "${ROOT_DIR}/lib/restore.sh"
# shellcheck source=../lib/cache.sh
source "${ROOT_DIR}/lib/cache.sh"
# shellcheck source=../lib/list.sh
source "${ROOT_DIR}/lib/list.sh"

backupctl_usage() {
  cat <<'EOF'
Usage: backupctl [global options] <command> [options]

Global Options:
  --config <path>  Path to node config file
                   (default: ~/.erpnext-nodes.json, initialized from config/nodes.json,
                   override via BACKUPCTL_CONFIG_PATH)
  --dry-run        Plan mode: show what would happen, make no changes
  -h, --help       Show this help

Commands:
  nodes list       List configured nodes
  scan             Discover backups on configured nodes
  list             List backups from cache (text/json, with filters)
  create           Create backup on frappe-node sources.        (to be tested)
  copy             Copy backup between nodes                    (to be tested)
  restore          Restore backup to target site                (to be tested)
  cache clear      Clear local cache files
  help             Show this help or command help

Examples:
  backupctl nodes list
  backupctl --config config/nodes.mkt.json nodes list
  backupctl scan --node own-prod-01
  backupctl list --format json --node own-prod-01 --complete true
  backupctl create --node own-prod-01 --site mysite.example.net --reason "before update"
  backupctl copy --backup <id> --from own-prod-01 --to archive-share
  backupctl --dry-run restore --backup <id> --to own-prod-01 --site mysite.example.net
  backupctl help scan
EOF
}

nodes_usage() {
  cat <<'EOF'
Usage: backupctl nodes list

Subcommands:
  list             List configured nodes
EOF
}

cache_usage() {
  cat <<'EOF'
Usage: backupctl cache clear

Subcommands:
  clear            Clear local cache files
EOF
}

backupctl_command_help() {
  local topic="${1:-}"

  case "${topic}" in
    ""|main)
      backupctl_usage
      ;;
    nodes)
      nodes_usage
      ;;
    scan)
      scan_usage
      ;;
    list)
      list_usage
      ;;
    create)
      backup_create_usage
      ;;
    copy)
      backup_copy_usage
      ;;
    restore)
      backup_restore_usage
      ;;
    cache)
      cache_usage
      ;;
    *)
      bt_die "Unknown help topic: ${topic}"
      ;;
  esac
}

main() {
  local config_path=""
  local dry_run_global=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config)
        [[ $# -ge 2 ]] || bt_die "--config requires a value"
        config_path="$2"
        shift 2
        ;;
      --dry-run)
        dry_run_global=1
        shift
        ;;
      -h|--help)
        backupctl_usage
        return
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    backupctl_usage
    exit 1
  fi

  if [[ -n "${config_path}" ]]; then
    bt_load_config "${config_path}"
  fi

  if [[ "${dry_run_global}" -eq 1 ]]; then
    BT_RUNNER_MODE="dry-run"
    export BT_RUNNER_MODE
  fi

  local command="$1"
  shift || true

  case "${command}" in
    help|-h|--help)
      backupctl_command_help "${1:-}"
      ;;
    nodes)
      if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
        nodes_usage
        return
      fi
      local subcommand="${1:-}"
      if [[ "${subcommand}" != "list" ]]; then
        bt_die "Unknown nodes subcommand: ${subcommand:-<empty>}"
      fi
      shift || true
      if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
        nodes_usage
        return
      fi
      nodes_list "$@"
      ;;
    scan)
      scan_main "$@"
      ;;
    list)
      list_main "$@"
      ;;
    create)
      backup_create_main "$@"
      ;;
    copy)
      backup_copy_main "$@"
      ;;
    restore)
      if [[ "${dry_run_global}" -eq 1 ]]; then
        backup_restore_main --dry-run "$@"
      else
      backup_restore_main "$@"
      fi
      ;;
    cache)
      if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
        cache_usage
        return
      fi
      local cache_subcommand="${1:-}"
      case "${cache_subcommand}" in
        clear)
          shift || true
          if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
            cache_usage
            return
          fi
          cache_clear_main "$@"
          ;;
        *)
          bt_die "Unknown cache subcommand: ${cache_subcommand:-<empty>}"
          ;;
      esac
      ;;
    *)
      bt_die "Unknown command: ${command}"
      ;;
  esac
}

main "$@"